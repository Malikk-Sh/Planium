# Пример настроек подписи релиза.
# 1. Скопируйте этот файл в keystore.properties (в корне проекта).
# 2. Положите ваш keystore (например, planium-release.jks) в корень проекта.
# 3. Заполните значения ниже.
# ВАЖНО: keystore.properties и сам .jks добавлены в .gitignore и НЕ попадают в репозиторий.

storeFile=planium-release.jks
storePassword=ВАШ_ПАРОЛЬ_ХРАНИЛИЩА
keyAlias=planium
keyPassword=ВАШ_ПАРОЛЬ_КЛЮЧА
